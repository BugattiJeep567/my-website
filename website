async function submitComment() {
  var remaining = checkCooldown('dns5_comment_cooldown');
  if (remaining > 0) {
    alert('⏳ Please wait ' + fmtCountdown(remaining) + ' before posting another comment.');
    return;
  }
  var artId = parseInt(document.getElementById('artPage').dataset.artId);
  var name  = document.getElementById('cmtName').value.trim();
  var text  = document.getElementById('cmtText').value.trim();
  if (!name||!text) { alert('Please enter your name and comment.'); return; }
  var a = articles.find(function(x){return x.id===artId;});
