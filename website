<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Denver News Station 5</title>
<link rel="icon" type="image/png" href="logo.png">
<link rel="apple-touch-icon" href="logo.png">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
[data-theme="dark"]{--bg:#0A0A0A;--surface:#141414;--mid:#1E1E1E;--border:#2A2A2A;--text:#DEDBD3;--muted:#888;--white:#F4F1EB;--input-bg:#1E1E1E;--modal-bg:#141414}
[data-theme="light"]{--bg:#F0EDE6;--surface:#FFFFFF;--mid:#F5F2EC;--border:#DDD8CE;--text:#2A2A2A;--muted:#777;--white:#111;--input-bg:#F5F2EC;--modal-bg:#FFFFFF}
:root{--red:#C8102E;--dark-red:#8B0A1E;--gold:#D4A843}
body{background:var(--bg);color:var(--text);font-family:Georgia,serif;min-height:100vh;transition:background .3s,color .3s}
/* BREAKING BAR */
.breaking-bar{background:var(--red);display:flex;align-items:center;height:34px;overflow:hidden}
.breaking-label{background:var(--bg);color:var(--red);font-family:monospace;font-size:11px;font-weight:bold;letter-spacing:2px;padding:0 14px;height:100%;display:flex;align-items:center;gap:8px;flex-shrink:0;transition:background .3s}
.live-dot{width:8px;height:8px;background:var(--red);border-radius:50%;animation:pulse 1.4s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(1.4)}}
.ticker-wrap{flex:1;overflow:hidden;height:100%;display:flex;align-items:center}
.ticker{white-space:nowrap;font-family:monospace;font-size:12px;color:#fff;padding-left:40px;animation:tickerAnim 35s linear infinite}
@keyframes tickerAnim{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}
/* HEADER */
.site-header{background:var(--surface);border-bottom:3px solid var(--red);transition:background .3s}
.header-main{display:flex;align-items:center;justify-content:space-between;padding:20px 40px;border-bottom:1px solid var(--border)}
.header-logo{display:flex;align-items:center;gap:16px;cursor:pointer}
.logo-badge{width:64px;height:64px;background:var(--red);color:#fff;font-size:44px;font-weight:900;display:flex;align-items:center;justify-content:center;border-radius:4px;box-shadow:0 0 0 3px var(--dark-red),0 4px 20px rgba(200,16,46,.4);flex-shrink:0}
.logo-badge.sm{width:28px;height:28px;font-size:18px;border-radius:3px}
.logo-city{font-size:34px;font-weight:900;color:var(--white);letter-spacing:3px;display:block}
.logo-sub{font-family:monospace;font-size:13px;letter-spacing:4px;color:var(--gold);display:block;margin-top:2px}
.header-date{font-family:monospace;font-size:12px;color:var(--muted);text-align:right;line-height:1.6}
/* NAV */
.main-nav{display:flex;align-items:center;justify-content:space-between;padding:0 40px;background:var(--mid);transition:background .3s}
.nav-left{display:flex;gap:4px}
.nav-btn{background:none;border:none;border-bottom:3px solid transparent;color:var(--muted);font-family:monospace;font-size:12px;letter-spacing:2px;padding:14px 22px;cursor:pointer;transition:all .2s}
.nav-btn:hover{color:var(--white);background:rgba(128,128,128,.08)}
.nav-btn.active{color:var(--white);border-bottom-color:var(--red)}
.nav-right{display:flex;align-items:center;gap:10px;padding:8px 0}
/* BUTTONS */
.signin-btn{background:var(--red);color:#fff;border:none;font-family:monospace;font-size:11px;letter-spacing:2px;padding:8px 18px;border-radius:3px;cursor:pointer;transition:background .2s}
.signin-btn:hover{background:var(--dark-red)}
.signout-btn{background:none;color:var(--muted);border:1px solid var(--border);font-family:monospace;font-size:11px;padding:7px 14px;border-radius:3px;cursor:pointer;transition:all .2s}
.signout-btn:hover{color:var(--white);border-color:var(--muted)}
.logged-label{font-family:monospace;font-size:11px;color:var(--gold)}
.btn-red{background:var(--red);color:#fff;border:none;font-family:monospace;font-size:12px;letter-spacing:2px;padding:13px 24px;border-radius:3px;cursor:pointer;transition:background .2s}
.btn-red:hover{background:var(--dark-red)}
.btn-ghost{background:none;color:var(--muted);border:1px solid var(--border);font-family:monospace;font-size:12px;padding:13px 18px;border-radius:3px;cursor:pointer;transition:all .2s}
.btn-ghost:hover{color:var(--white);border-color:var(--muted)}
.theme-toggle{background:none;border:1px solid var(--border);color:var(--muted);width:34px;height:34px;border-radius:50%;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.theme-toggle:hover{border-color:var(--red);color:var(--white)}
/* TICKER EDIT */
.ticker-edit-bar{background:var(--surface);border-bottom:1px solid var(--border);padding:8px 40px;display:none;align-items:center;gap:10px}
.ticker-edit-bar.show{display:flex}
.ticker-edit-bar input{flex:1;background:var(--mid);border:1px solid var(--border);border-radius:3px;color:var(--white);font-family:monospace;font-size:12px;padding:7px 12px;outline:none}
.ticker-edit-bar input:focus{border-color:var(--red)}
/* ANNOUNCEMENT */
.announce-bar{background:var(--gold);color:#000;padding:10px 40px;display:none;align-items:center;gap:12px}
.announce-bar.visible{display:flex}
.announce-text{flex:1;font-family:monospace;font-size:13px;font-weight:bold;letter-spacing:1px;text-align:center}
.announce-dismiss{background:rgba(0,0,0,.15);border:none;color:#000;width:26px;height:26px;border-radius:50%;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .2s}
.announce-dismiss:hover{background:rgba(0,0,0,.3)}
.announce-edit-bar{background:#a07c00;border-bottom:1px solid rgba(0,0,0,.2);padding:8px 40px;display:none;align-items:center;gap:10px}
.announce-edit-bar.show{display:flex}
.announce-edit-bar input{flex:1;background:rgba(0,0,0,.2);border:1px solid rgba(0,0,0,.3);border-radius:3px;color:#fff;font-family:monospace;font-size:12px;padding:7px 12px;outline:none}
.announce-edit-bar input::placeholder{color:rgba(255,255,255,.5)}
.announce-toggle-btn{background:rgba(0,0,0,.2);border:1px solid rgba(0,0,0,.3);color:#fff;font-family:monospace;font-size:11px;letter-spacing:1px;padding:7px 14px;border-radius:3px;cursor:pointer;white-space:nowrap;transition:background .2s}
.announce-toggle-btn:hover{background:rgba(0,0,0,.35)}
/* LOADING OVERLAY */
.loading-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.loading-spinner{width:48px;height:48px;border:4px solid var(--border);border-top-color:var(--red);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
/* SEARCH */
.search-wrap{max-width:1100px;margin:0 auto;padding:24px 20px 0}
.search-box{display:flex;background:var(--surface);border:2px solid var(--border);border-radius:6px;overflow:hidden;transition:border-color .2s}
.search-box:focus-within{border-color:var(--red)}
.search-box input{flex:1;background:none;border:none;color:var(--text);font-family:Georgia,serif;font-size:16px;padding:14px 20px;outline:none}
.search-box input::placeholder{color:var(--muted)}
.search-box button{background:var(--red);border:none;color:#fff;font-family:monospace;font-size:12px;letter-spacing:2px;padding:14px 24px;cursor:pointer;transition:background .2s;flex-shrink:0}
.search-box button:hover{background:var(--dark-red)}
.search-clear{background:none;border:none;color:var(--muted);font-family:monospace;font-size:12px;padding:14px 16px;cursor:pointer;transition:color .2s}
.search-clear:hover{color:var(--white)}
.search-results-label{font-family:monospace;font-size:11px;letter-spacing:2px;color:var(--muted);margin:20px 0 -8px}
/* REPORTER PAGE */
.reporter-page{position:fixed;inset:0;background:var(--bg);z-index:1500;transform:translateY(100%);transition:transform .38s cubic-bezier(.4,0,.2,1);overflow-y:auto}
.reporter-page.open{transform:translateY(0)}
.reporter-page-bar{position:sticky;top:0;background:var(--surface);border-bottom:3px solid var(--red);padding:14px 40px;display:flex;align-items:center;gap:16px;z-index:10}
.reporter-page-bar button{background:var(--mid);border:1px solid var(--border);color:var(--muted);padding:9px 18px;border-radius:3px;font-family:monospace;font-size:12px;cursor:pointer;transition:all .2s}
.reporter-page-bar button:hover{color:var(--white);border-color:var(--red)}
.reporter-hero{background:linear-gradient(135deg,#1a0508,#0a0a0a);padding:60px 40px;text-align:center;border-bottom:1px solid var(--border)}
.reporter-avatar{width:120px;height:120px;border-radius:50%;object-fit:cover;border:4px solid var(--red);box-shadow:0 0 0 6px rgba(200,16,46,.2);margin:0 auto 20px;display:block}
.reporter-avatar-placeholder{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,var(--dark-red),#1a0508);border:4px solid var(--red);display:flex;align-items:center;justify-content:center;font-size:48px;margin:0 auto 20px}
.reporter-name{font-size:36px;font-weight:700;color:var(--white);margin-bottom:8px}
.reporter-role-badge{font-family:monospace;font-size:11px;letter-spacing:3px;color:var(--red);background:rgba(200,16,46,.15);border:1px solid rgba(200,16,46,.3);padding:6px 16px;border-radius:2px;display:inline-block;margin-bottom:16px}
.reporter-bio{font-size:15px;color:var(--muted);max-width:600px;margin:0 auto;line-height:1.7}
.reporter-stats{display:flex;gap:40px;justify-content:center;padding:28px 40px;border-bottom:1px solid var(--border);background:var(--surface)}
.reporter-stat{text-align:center}
.reporter-stat-num{font-size:32px;font-weight:700;color:var(--white);display:block}
.reporter-stat-label{font-family:monospace;font-size:10px;letter-spacing:2px;color:var(--muted)}
.reporter-link{color:var(--red);cursor:pointer;text-decoration:underline;text-underline-offset:3px}
.reporter-link:hover{color:var(--gold)}
.reporter-articles{max-width:1100px;margin:0 auto;padding:40px 20px}
.reporter-articles h3{font-family:monospace;font-size:12px;letter-spacing:3px;color:var(--gold);margin-bottom:24px;padding-bottom:12px;border-bottom:1px solid var(--border)}
/* TABS */
.tab{display:none}.tab.active{display:block}
.cat-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px}
.cat-filter-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:monospace;font-size:11px;letter-spacing:1px;padding:6px 14px;border-radius:20px;cursor:pointer;transition:all .2s}
.cat-filter-btn:hover,.cat-filter-btn.active{background:var(--red);color:#fff;border-color:var(--red)}
/* HOME */
.homepage{max-width:1100px;margin:0 auto;padding:40px 20px}
.hero-article{display:grid;grid-template-columns:1fr 400px;background:var(--surface);border:1px solid var(--border);border-radius:6px;overflow:hidden;min-height:380px;cursor:pointer;transition:border-color .2s;margin-bottom:32px;position:relative}
.hero-article:hover{border-color:var(--red)}
.hero-img-wrap img{width:100%;height:100%;min-height:380px;object-fit:cover;display:block}
.hero-no-img{background:linear-gradient(135deg,#2a0a10,#0a0a0a);min-height:380px;display:flex;align-items:center;justify-content:center;font-size:140px;font-weight:900;color:rgba(200,16,46,.12)}
.hero-info{padding:36px;display:flex;flex-direction:column;justify-content:flex-end}
.cat-tag{font-family:monospace;font-size:10px;letter-spacing:2px;color:var(--red);background:rgba(200,16,46,.15);border:1px solid rgba(200,16,46,.3);padding:4px 10px;border-radius:2px;display:inline-block;margin-bottom:14px;align-self:flex-start}
.hero-info h2{font-size:26px;font-weight:700;color:var(--white);line-height:1.25;margin-bottom:10px}
.art-meta{font-family:monospace;font-size:11px;color:var(--muted);margin-bottom:14px}
.hero-excerpt{font-size:14px;color:var(--text);line-height:1.7;margin-bottom:20px}
.read-btn{background:var(--red);color:#fff;border:none;font-family:monospace;font-size:11px;letter-spacing:2px;padding:10px 20px;border-radius:2px;cursor:pointer;align-self:flex-start;transition:background .2s}
.read-btn:hover{background:var(--dark-red)}
.pin-badge{position:absolute;top:14px;left:14px;background:var(--gold);color:#000;font-family:monospace;font-size:10px;letter-spacing:2px;padding:4px 10px;border-radius:2px;font-weight:bold}
.admin-btns{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.admin-btn{font-family:monospace;font-size:11px;padding:7px 14px;border-radius:3px;cursor:pointer;border:none}
.del-btn{background:rgba(200,16,46,.85);color:#fff}.del-btn:hover{background:var(--dark-red)}
.pin-btn{background:rgba(212,168,67,.2);color:var(--gold);border:1px solid rgba(212,168,67,.4)!important}.pin-btn:hover{background:rgba(212,168,67,.35)}
.news-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:6px;overflow:hidden;cursor:pointer;transition:transform .2s,border-color .2s;position:relative}
.card:hover{transform:translateY(-3px);border-color:var(--red)}
.card-img{width:100%;height:200px;object-fit:cover}
.card-no-img{width:100%;height:200px;background:linear-gradient(135deg,var(--mid),var(--surface));display:flex;align-items:center;justify-content:center;font-size:60px;font-weight:900;color:rgba(200,16,46,.12)}
.card-body{padding:20px}
.card-body h3{font-size:18px;font-weight:700;color:var(--white);margin:10px 0 6px;line-height:1.3}
.card-excerpt{font-size:13px;color:var(--muted);line-height:1.6}
.card-admin{position:absolute;top:8px;right:8px;display:none;gap:6px}
.card:hover .card-admin{display:flex}
/* MODALS */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:2000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.modal-box{background:var(--modal-bg);border:1px solid var(--border);border-radius:8px;width:100%;max-width:460px;padding:48px 40px;animation:fadeUp .22s ease;position:relative}
.modal-close-btn{position:absolute;top:14px;right:14px;background:rgba(0,0,0,.5);border:1px solid var(--border);color:var(--muted);width:34px;height:34px;border-radius:50%;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;z-index:10;transition:all .2s}
.modal-close-btn:hover{border-color:var(--red);color:var(--white)}
/* ARTICLE FULL PAGE */
.art-page{position:fixed;inset:0;background:var(--bg);z-index:1500;transform:translateY(100%);transition:transform .38s cubic-bezier(.4,0,.2,1);overflow-y:auto;display:flex;flex-direction:column}
.art-page.open{transform:translateY(0)}
.art-page-bar{position:sticky;top:0;z-index:10;background:var(--surface);border-bottom:3px solid var(--red);padding:14px 40px;display:flex;align-items:center;gap:16px}
.art-page-bar button{background:var(--mid);border:1px solid var(--border);color:var(--muted);padding:9px 18px;border-radius:3px;font-family:monospace;font-size:12px;cursor:pointer;transition:all .2s}
.art-page-bar button:hover{color:var(--white);border-color:var(--red)}
.art-page-bar .station-label{font-family:monospace;font-size:11px;color:var(--muted);letter-spacing:2px;margin-left:auto}
.art-page-hero{width:100%;max-height:520px;object-fit:cover;display:block}
.art-page-body-wrap{max-width:860px;margin:0 auto;padding:60px 40px;width:100%}
.art-page-body-wrap h2{font-size:42px;font-weight:700;color:var(--white);line-height:1.15;margin:20px 0 14px}
.art-page-caption{font-family:monospace;font-size:11px;color:var(--muted);font-style:italic;margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.art-page-text{font-size:20px;line-height:2;color:var(--text);white-space:pre-wrap}
/* COMMENTS */
.comments-section{margin-top:28px;padding-top:24px;border-top:1px solid var(--border)}
.comments-section h4{font-family:monospace;font-size:11px;letter-spacing:3px;color:var(--gold);margin-bottom:16px}
.comment-item{background:var(--mid);border-radius:4px;padding:12px 16px;margin-bottom:10px}
.comment-author{font-family:monospace;font-size:11px;color:var(--red);margin-bottom:4px}
.comment-text{font-size:14px;color:var(--text);line-height:1.6}
.comment-time{font-family:monospace;font-size:10px;color:var(--muted);margin-top:4px}
.comment-form{display:flex;flex-direction:column;gap:10px;margin-top:16px}
.comment-form input,.comment-form textarea{background:var(--input-bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:Georgia,serif;font-size:14px;padding:10px 14px;outline:none;transition:border-color .2s}
.comment-form input:focus,.comment-form textarea:focus{border-color:var(--red)}
.comment-form textarea{resize:vertical;min-height:80px}
.comment-submit{background:var(--red);color:#fff;border:none;font-family:monospace;font-size:11px;letter-spacing:2px;padding:10px 20px;border-radius:3px;cursor:pointer;align-self:flex-start}
/* LOGIN */
.login-box h2{font-size:22px;color:var(--white);margin-bottom:6px}
.login-box p{font-family:monospace;font-size:11px;color:var(--muted);margin-bottom:28px}
.lf{margin-bottom:18px}
.lf label{display:block;font-family:monospace;font-size:11px;letter-spacing:2px;color:var(--muted);margin-bottom:8px}
.lf input{width:100%;background:var(--input-bg);border:1px solid var(--border);border-radius:4px;color:var(--white);font-size:15px;padding:12px 14px;outline:none;transition:border-color .2s}
.lf input:focus{border-color:var(--red)}
.login-err{color:#e87985;font-family:monospace;font-size:12px;margin-bottom:14px;display:none}
/* WRITE */
.write-wrap{max-width:820px;margin:0 auto;padding:50px 20px}
.sec-title{font-family:monospace;font-size:13px;letter-spacing:4px;color:var(--gold);margin-bottom:36px;padding-bottom:16px;border-bottom:2px solid var(--border);display:flex;align-items:center;gap:12px}
.fg{margin-bottom:22px}
.fg label{display:block;font-family:monospace;font-size:11px;letter-spacing:2px;color:var(--muted);margin-bottom:8px}
.fg input,.fg select,.fg textarea{width:100%;background:var(--input-bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:Georgia,serif;font-size:15px;padding:12px 16px;outline:none;transition:border-color .2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--red)}
.fg select option{background:var(--input-bg)}
.fg textarea{resize:vertical;line-height:1.8}
.drop-zone{background:var(--input-bg);border:2px dashed var(--border);border-radius:6px;padding:36px;text-align:center;cursor:pointer;transition:all .2s}
.drop-zone:hover,.drop-zone.dragover{border-color:var(--red);background:rgba(200,16,46,.06)}
.drop-icon{font-size:32px;margin-bottom:10px}
.img-preview{position:relative;margin-top:12px}
.img-preview img{width:100%;max-height:260px;object-fit:cover;border-radius:4px;border:1px solid var(--border)}
.rm-img{position:absolute;top:10px;right:10px;background:rgba(0,0,0,.75);color:#fff;border:1px solid rgba(255,255,255,.2);border-radius:4px;padding:6px 12px;font-family:monospace;font-size:11px;cursor:pointer}
.rm-img:hover{background:var(--red)}
.pub-msg{margin-top:16px;padding:12px 18px;border-radius:4px;font-family:monospace;font-size:13px;display:none}
.pub-msg.ok{background:rgba(40,167,69,.15);border:1px solid rgba(40,167,69,.4);color:#6dcf7e}
.pub-msg.err{background:rgba(200,16,46,.15);border:1px solid rgba(200,16,46,.4);color:#e87985}
/* ABOUT */
.about-wrap{max-width:1000px;margin:0 auto;padding:50px 20px}
.about-header{text-align:center;margin-bottom:60px}
.about-header h2{font-size:36px;color:var(--white);letter-spacing:3px;margin-bottom:10px}
.about-header p{color:var(--muted);font-family:monospace;font-size:12px;letter-spacing:2px}
.staff-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:28px}
.staff-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:32px 24px;text-align:center;transition:border-color .2s,transform .2s}
.staff-card:hover{border-color:var(--red);transform:translateY(-2px)}
.staff-avatar{width:100px;height:100px;border-radius:50%;object-fit:cover;border:3px solid var(--red);box-shadow:0 0 0 4px rgba(200,16,46,.2);margin:0 auto 20px;display:block}
.staff-avatar-placeholder{width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,var(--dark-red),#0a0a0a);border:3px solid var(--red);display:flex;align-items:center;justify-content:center;font-size:36px;color:rgba(255,255,255,.3);margin:0 auto 20px}
.staff-name{font-size:20px;font-weight:700;color:var(--white);margin-bottom:6px}
.staff-role{font-family:monospace;font-size:11px;letter-spacing:2px;color:var(--red);background:rgba(200,16,46,.15);border:1px solid rgba(200,16,46,.3);padding:4px 12px;border-radius:2px;display:inline-block;margin-bottom:14px}
.staff-bio{font-size:13px;color:var(--muted);line-height:1.7}
.staff-edit-btns{display:flex;gap:8px;justify-content:center;margin-top:16px}
.add-staff-btn{background:rgba(200,16,46,.15);border:2px dashed rgba(200,16,46,.4);border-radius:8px;padding:40px 24px;text-align:center;cursor:pointer;transition:all .2s;color:var(--red);font-family:monospace;font-size:13px;letter-spacing:2px}
.add-staff-btn:hover{background:rgba(200,16,46,.25)}
/* APPLY */
.apply-wrap{max-width:820px;margin:0 auto;padding:50px 20px}
.apply-head{display:flex;align-items:center;gap:24px;margin-bottom:50px;padding-bottom:28px;border-bottom:2px solid var(--border)}
.apply-badge{width:80px;height:80px;background:var(--red);color:#fff;font-size:52px;font-weight:900;display:flex;align-items:center;justify-content:center;border-radius:6px;flex-shrink:0;box-shadow:0 0 0 4px var(--dark-red),0 8px 30px rgba(200,16,46,.4)}
.apply-head h2{font-size:28px;color:var(--white);letter-spacing:2px;margin-bottom:8px}
.apply-head p{color:var(--muted);font-size:14px;line-height:1.6}
.asec{margin-bottom:40px}
.asec h3{font-family:monospace;font-size:11px;letter-spacing:3px;color:var(--gold);margin-bottom:18px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.s-tag{font-family:monospace;font-size:10px;letter-spacing:2px;color:var(--red);background:rgba(200,16,46,.15);border:1px solid rgba(200,16,46,.3);padding:3px 8px;border-radius:2px;display:inline-block;margin-bottom:8px}
.scenario-q{font-size:14px;color:var(--text);margin-bottom:10px;line-height:1.5}
/* APPS PANEL */
.apps-wrap{max-width:900px;margin:0 auto;padding:50px 20px}
.app-tabs{display:flex;gap:0;margin-bottom:28px;border-bottom:2px solid var(--border)}
.app-tab-btn{background:none;border:none;border-bottom:3px solid transparent;margin-bottom:-2px;color:var(--muted);font-family:monospace;font-size:12px;letter-spacing:2px;padding:12px 22px;cursor:pointer;transition:all .2s}
.app-tab-btn.active{color:var(--white);border-bottom-color:var(--red)}
.app-item{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:24px;margin-bottom:16px}
.app-item-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px}
.app-item h3{font-size:16px;color:var(--white);margin-bottom:4px}
.app-item .app-ids{font-family:monospace;font-size:11px;color:var(--muted)}
.app-section{margin-bottom:14px}
.app-section-label{font-family:monospace;font-size:10px;letter-spacing:2px;color:var(--gold);margin-bottom:6px}
.app-section-text{font-size:13px;color:var(--text);line-height:1.6;background:var(--mid);padding:10px 14px;border-radius:4px;white-space:pre-wrap}
.app-decision-btns{display:flex;gap:8px;margin-top:14px}
.accept-btn{background:rgba(40,167,69,.2);color:#6dcf7e;border:1px solid rgba(40,167,69,.4);font-family:monospace;font-size:11px;padding:8px 16px;border-radius:3px;cursor:pointer;transition:all .2s}
.accept-btn:hover{background:rgba(40,167,69,.35)}
.deny-btn{background:rgba(200,16,46,.2);color:#e87985;border:1px solid rgba(200,16,46,.4);font-family:monospace;font-size:11px;padding:8px 16px;border-radius:3px;cursor:pointer;transition:all .2s}
.deny-btn:hover{background:rgba(200,16,46,.35)}
.status-badge{font-family:monospace;font-size:10px;letter-spacing:2px;padding:4px 10px;border-radius:2px;display:inline-block}
.status-badge.accepted{background:rgba(40,167,69,.15);color:#6dcf7e;border:1px solid rgba(40,167,69,.3)}
.status-badge.denied{background:rgba(200,16,46,.15);color:#e87985;border:1px solid rgba(200,16,46,.3)}
.status-badge.pending{background:rgba(212,168,67,.15);color:var(--gold);border:1px solid rgba(212,168,67,.3)}
.no-apps{text-align:center;padding:60px 20px;color:var(--muted);font-family:monospace}
/* COOLDOWN */
.cooldown-msg{background:rgba(200,16,46,.12);border:1px solid rgba(200,16,46,.35);color:#e87985;font-family:monospace;font-size:12px;padding:12px 18px;border-radius:4px;margin-top:14px;display:none}
/* SUCCESS */
.success-box{text-align:center;padding:80px 40px}
.success-icon{width:80px;height:80px;background:rgba(40,167,69,.12);border:2px solid rgba(40,167,69,.4);color:#6dcf7e;font-size:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px}
.success-box h3{font-size:26px;color:var(--white);margin-bottom:12px}
.success-box p{color:var(--muted);font-size:14px;max-width:480px;margin:0 auto 28px;line-height:1.7}
/* CONTACT */
.contact-wrap{max-width:700px;margin:0 auto;padding:50px 20px}
.contact-header{display:flex;align-items:center;gap:20px;margin-bottom:50px;padding-bottom:28px;border-bottom:2px solid var(--border)}
.contact-icon{width:72px;height:72px;background:var(--red);color:#fff;font-size:34px;display:flex;align-items:center;justify-content:center;border-radius:6px;flex-shrink:0;box-shadow:0 0 0 3px var(--dark-red),0 4px 20px rgba(200,16,46,.3)}
.contact-header h2{font-size:28px;color:var(--white);letter-spacing:2px;margin-bottom:6px}
.contact-header p{color:var(--muted);font-size:14px;line-height:1.6}
.contact-type-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:6px}
.contact-type-btn{background:var(--mid);border:2px solid var(--border);border-radius:6px;padding:16px;cursor:pointer;text-align:left;transition:all .2s;width:100%}
.contact-type-btn:hover{border-color:var(--red)}
.contact-type-btn.selected{border-color:var(--red);background:rgba(200,16,46,.1)}
.ct-icon{font-size:22px;margin-bottom:6px;display:block}
.ct-label{font-family:monospace;font-size:11px;letter-spacing:2px;color:var(--red);display:block;margin-bottom:3px}
.ct-desc{font-size:12px;color:var(--muted);line-height:1.4}
.contact-success{text-align:center;padding:60px 20px;animation:fadeUp .3s ease}
.contact-success h3{font-size:24px;color:var(--white);margin-bottom:10px}
.contact-success p{color:var(--muted);font-size:14px;line-height:1.7;max-width:400px;margin:0 auto 24px}
/* MESSAGES */
.msgs-wrap{max-width:960px;margin:0 auto;padding:50px 20px}
.msg-item{background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--border);border-radius:6px;padding:24px;margin-bottom:16px;transition:border-color .2s}
.msg-item.unread{border-left-color:var(--red)}
.msg-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;gap:12px}
.msg-from{font-size:16px;font-weight:700;color:var(--white);margin-bottom:3px}
.msg-discord{font-family:monospace;font-size:11px;color:var(--red)}
.msg-meta{font-family:monospace;font-size:10px;color:var(--muted);text-align:right;flex-shrink:0;line-height:1.8}
.msg-type-badge{font-family:monospace;font-size:9px;letter-spacing:2px;padding:3px 8px;border-radius:2px;display:inline-block}
.msg-subject{font-family:monospace;font-size:11px;letter-spacing:1px;color:var(--gold);margin-bottom:10px}
.msg-body{font-size:14px;color:var(--text);line-height:1.7;background:var(--mid);padding:14px 16px;border-radius:4px;white-space:pre-wrap}
.msg-actions{display:flex;gap:8px;margin-top:14px}
.unread-badge{background:var(--red);color:#fff;font-family:monospace;font-size:10px;padding:2px 8px;border-radius:10px;margin-left:8px}
/* LOGS */
.logs-wrap{max-width:960px;margin:0 auto;padding:50px 20px}
.log-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px}
.log-filter-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:monospace;font-size:11px;letter-spacing:1px;padding:5px 14px;border-radius:20px;cursor:pointer;transition:all .2s}
.log-filter-btn:hover,.log-filter-btn.active{background:var(--red);color:#fff;border-color:var(--red)}
.log-item{display:flex;align-items:flex-start;gap:16px;padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:6px;margin-bottom:10px}
.log-icon{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;margin-top:2px}
.log-icon.login{background:rgba(100,160,255,.15)}
.log-icon.article{background:rgba(40,167,69,.15)}
.log-icon.delete{background:rgba(200,16,46,.15)}
.log-icon.app{background:rgba(212,168,67,.15)}
.log-icon.msg{background:rgba(180,100,255,.15)}
.log-icon.staff{background:rgba(100,200,200,.15)}
.log-icon.pin{background:rgba(212,168,67,.15)}
.log-icon.announce{background:rgba(255,165,0,.15)}
.log-body{flex:1}
.log-text{font-size:14px;color:var(--text);line-height:1.5;margin-bottom:4px}
.log-text strong{color:var(--white)}
.log-sub{font-family:monospace;font-size:11px;color:var(--muted)}
.log-time{font-family:monospace;font-size:11px;color:var(--muted);flex-shrink:0;white-space:nowrap}
.log-location{display:inline-block;background:rgba(100,160,255,.1);border:1px solid rgba(100,160,255,.25);color:#6ab4ff;font-family:monospace;font-size:10px;padding:2px 8px;border-radius:10px;margin-left:8px}
.no-logs{text-align:center;padding:60px 20px;color:var(--muted);font-family:monospace;font-size:13px}
/* ARCHIVE */
.archive-wrap{max-width:1100px;margin:0 auto;padding:50px 20px}
.archive-month{margin-bottom:48px}
.archive-month-title{font-family:monospace;font-size:13px;letter-spacing:4px;color:var(--gold);margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.archive-month-count{font-size:11px;color:var(--muted);letter-spacing:1px}
.archive-list{display:flex;flex-direction:column;gap:12px}
.archive-item{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:16px 20px;cursor:pointer;display:flex;align-items:center;gap:16px;transition:border-color .2s}
.archive-item:hover{border-color:var(--red)}
.archive-item-img{width:70px;height:55px;object-fit:cover;border-radius:4px;flex-shrink:0}
.archive-item-no-img{width:70px;height:55px;background:var(--mid);border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:900;color:rgba(200,16,46,.2)}
.archive-item-info{flex:1}
.archive-item-info h3{font-size:16px;font-weight:700;color:var(--white);margin-bottom:4px;line-height:1.3}
.archive-item-meta{font-family:monospace;font-size:11px;color:var(--muted)}
.archive-item-views{font-family:monospace;font-size:11px;color:var(--muted);flex-shrink:0}
/* GALLERY */
.gallery-wrap{max-width:1100px;margin:0 auto;padding:50px 20px}
.gallery-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;padding-bottom:16px;border-bottom:2px solid var(--border)}
.gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.gallery-item{background:var(--surface);border:1px solid var(--border);border-radius:6px;overflow:hidden;cursor:pointer;transition:transform .2s,border-color .2s;position:relative}
.gallery-item:hover{transform:translateY(-3px);border-color:var(--red)}
.gallery-item img{width:100%;height:220px;object-fit:cover;display:block}
.gallery-caption{padding:12px 16px;font-size:13px;color:var(--muted);line-height:1.5}
.gallery-delete{position:absolute;top:8px;right:8px;background:rgba(200,16,46,.85);color:#fff;border:none;font-family:monospace;font-size:11px;padding:5px 10px;border-radius:3px;cursor:pointer;display:none}
.gallery-item:hover .gallery-delete{display:block}
.gallery-upload-box{background:rgba(200,16,46,.1);border:2px dashed rgba(200,16,46,.4);border-radius:8px;padding:40px;text-align:center;cursor:pointer;transition:all .2s;color:var(--red);font-family:monospace;font-size:13px;letter-spacing:2px;margin-bottom:24px}
.gallery-upload-box:hover{background:rgba(200,16,46,.2)}
.gallery-lightbox{position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:3000;display:flex;align-items:center;justify-content:center;cursor:pointer}
.gallery-lightbox img{max-width:90vw;max-height:85vh;object-fit:contain;border-radius:4px}
.gallery-lightbox-caption{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);color:#fff;font-size:14px;font-family:monospace;background:rgba(0,0,0,.6);padding:8px 20px;border-radius:20px;white-space:nowrap}
/* VIEW COUNTER */
.view-count{font-family:monospace;font-size:11px;color:var(--muted);display:inline-flex;align-items:center;gap:4px}
/* REPORTER DASHBOARD */
.dashboard-wrap{max-width:960px;margin:0 auto;padding:50px 20px}
.dash-welcome{background:linear-gradient(135deg,#1a0508,var(--surface));border:1px solid var(--border);border-radius:8px;padding:36px;margin-bottom:32px;display:flex;align-items:center;gap:24px}
.dash-avatar{width:80px;height:80px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-size:36px;flex-shrink:0;border:3px solid var(--dark-red)}
.dash-welcome h2{font-size:28px;color:var(--white);margin-bottom:6px}
.dash-welcome p{color:var(--muted);font-size:14px}
.dash-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px}
.dash-stat{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:24px;text-align:center}
.dash-stat-num{font-size:36px;font-weight:700;color:var(--white);display:block;margin-bottom:4px}
.dash-stat-label{font-family:monospace;font-size:10px;letter-spacing:2px;color:var(--muted)}
.dash-articles-title{font-family:monospace;font-size:12px;letter-spacing:3px;color:var(--gold);margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border)}
/* FOOTER */
.site-footer{background:var(--surface);border-top:1px solid var(--border);margin-top:60px;padding:28px 40px;transition:background .3s}
.footer-in{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between}
.footer-logo{display:flex;align-items:center;gap:10px;font-size:17px;font-weight:700;color:var(--white)}
.site-footer p{font-family:monospace;font-size:11px;color:var(--muted)}
@media(max-width:768px){
  .header-main{padding:16px 20px}.logo-city{font-size:22px}.logo-badge{width:48px;height:48px;font-size:30px}
  .main-nav{padding:0 10px;flex-wrap:wrap}.hero-article{grid-template-columns:1fr}
  .hero-img-wrap img,.hero-no-img{min-height:200px}.form-row{grid-template-columns:1fr}
  .footer-in{flex-direction:column;gap:12px;text-align:center}.ticker-edit-bar{padding:8px 16px}
}
</style>
</head>
<body>

<!-- LOADING OVERLAY -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
</div>

<!-- BREAKING BAR -->
<div class="breaking-bar">
  <div class="breaking-label"><div class="live-dot"></div>LIVE</div>
  <div class="ticker-wrap"><div class="ticker" id="ticker">DENVER NEWS STATION 5 &nbsp;•&nbsp; YOUR LOCAL SOURCE FOR TRUTH &nbsp;•&nbsp; STAY INFORMED, DENVER</div></div>
</div>

<!-- HEADER -->
<div class="site-header">
  <div class="header-main">
    <div class="header-logo" onclick="showTab('home')">
      <div class="logo-badge">5</div>
      <div><span class="logo-city">DENVER</span><span class="logo-sub">NEWS STATION</span></div>
    </div>
    <div class="header-date" id="headerDate"></div>
  </div>
  <nav class="main-nav">
    <div class="nav-left">
      <button class="nav-btn active" onclick="showTab('home')">HOME</button>
      <button class="nav-btn" onclick="showTab('about')">ABOUT</button>
      <button class="nav-btn" onclick="showTab('archive')">ARCHIVE</button>
      <button class="nav-btn" onclick="showTab('gallery')">GALLERY</button>
      <button class="nav-btn" onclick="showTab('apply')">APPLY</button>
      <button class="nav-btn" onclick="showTab('contact')">CONTACT</button>
    </div>
    <div class="nav-right">
      <button class="theme-toggle" onclick="toggleTheme()" id="themeBtn">🌙</button>
      <div id="navAuthArea"><button class="signin-btn" onclick="openLogin()">SIGN IN</button></div>
    </div>
  </nav>
</div>

<!-- TICKER EDIT BAR -->
<div class="ticker-edit-bar" id="tickerBar">
  <span style="font-family:monospace;font-size:11px;letter-spacing:2px;color:var(--gold);flex-shrink:0;">TICKER:</span>
  <input type="text" id="tickerInput" placeholder="Custom ticker text... (blank = use headlines)">
  <button class="btn-red" style="padding:8px 16px;font-size:11px;" onclick="saveTicker()">UPDATE</button>
  <button class="btn-ghost" style="padding:8px 14px;font-size:11px;" onclick="clearTicker()">RESET</button>
</div>

<!-- ANNOUNCEMENT EDIT BAR -->
<div class="announce-edit-bar" id="announceEditBar">
  <span style="font-family:monospace;font-size:11px;letter-spacing:2px;color:#fff;flex-shrink:0;">📢 ANNOUNCEMENT:</span>
  <input type="text" id="announceInput" placeholder="Type your announcement text...">
  <button class="announce-toggle-btn" onclick="saveAnnounce()">UPDATE</button>
  <button class="announce-toggle-btn" id="announceToggleBtn" onclick="toggleAnnounce()">SHOW</button>
  <button class="announce-toggle-btn" onclick="clearAnnounce()">CLEAR</button>
</div>

<!-- ANNOUNCEMENT BAR -->
<div class="announce-bar" id="announceBar">
  <div class="announce-text" id="announceText"></div>
  <button class="announce-dismiss" onclick="dismissAnnounce()">✕</button>
</div>

<!-- HOME TAB -->
<div id="tab-home" class="tab active">
  <div class="search-wrap">
    <div class="search-box">
      <input type="text" id="searchInput" placeholder="Search articles..." onkeydown="if(event.key==='Enter')doSearch()" oninput="if(this.value==='')clearSearch()">
      <button class="search-clear" id="searchClearBtn" onclick="clearSearch()" style="display:none">✕</button>
      <button onclick="doSearch()">SEARCH</button>
    </div>
    <div id="searchResultsLabel" class="search-results-label" style="display:none"></div>
  </div>
  <div class="homepage">
    <div class="cat-filters" id="catFilters"></div>
    <div id="heroSlot"></div>
    <div class="news-grid" id="newsGrid"></div>
  </div>
</div>

<!-- ABOUT TAB -->
<div id="tab-about" class="tab">
  <div class="about-wrap">
    <div class="about-header"><h2>OUR TEAM</h2><p>THE PEOPLE BEHIND DENVER NEWS STATION 5</p></div>
    <div class="staff-grid" id="staffGrid"></div>
  </div>
</div>

<!-- APPLY TAB -->
<div id="tab-apply" class="tab">
  <div class="apply-wrap">
    <div id="applyFormWrap">
      <div class="apply-head">
        <div class="apply-badge">5</div>
        <div><h2>JOIN OUR TEAM</h2><p>Denver News Station 5 is looking for passionate reporters, journalists, and media professionals.</p></div>
      </div>
      <div class="asec"><h3>YOUR ACCOUNTS</h3>
        <div class="form-row">
          <div class="fg"><label>DISCORD USERNAME *</label><input type="text" id="appDiscord" placeholder="username or @username"></div>
          <div class="fg"><label>ROBLOX USERNAME *</label><input type="text" id="appRoblox" placeholder="Your Roblox username"></div>
        </div>
      </div>
      <div class="asec"><h3>EXPERIENCE</h3>
        <div class="fg"><label>PAST EXPERIENCE *</label><textarea id="appExp" rows="5" placeholder="Describe your previous experience..."></textarea></div>
      </div>
      <div class="asec"><h3>WRITING SAMPLES</h3>
        <div class="fg"><div class="s-tag">SCENARIO 1 — BREAKING NEWS</div><div class="scenario-q">How would you write a report on a fire at a hospital?</div><textarea id="appFire" rows="8" placeholder="Write your full news report here..."></textarea></div>
        <div class="fg"><div class="s-tag">SCENARIO 2 — CRIME</div><div class="scenario-q">How would you write a report on someone who murdered 4 people and was arrested?</div><textarea id="appMurder" rows="8" placeholder="Write your full news report here..."></textarea></div>
      </div>
      <button class="btn-red" onclick="submitApp()">SUBMIT APPLICATION</button>
      <div class="cooldown-msg" id="appCooldownMsg"></div>
    </div>
    <div id="applySuccess" class="success-box" style="display:none">
      <div class="success-icon">✓</div>
      <h3>APPLICATION SUBMITTED!</h3>
      <p>Thank you for applying to Denver News Station 5. Our team will review your application and reach out via Discord shortly.</p>
      <button class="btn-ghost" onclick="resetApp()">SUBMIT ANOTHER</button>
    </div>
  </div>
</div>

<!-- CONTACT TAB -->
<div id="tab-contact" class="tab">
  <div class="contact-wrap">
    <div id="contactFormWrap">
      <div class="contact-header">
        <div class="contact-icon">📬</div>
        <div><h2>CONTACT US</h2><p>Have a question, tip, or want to reach out? Fill out the form below and we'll get back to you via Discord.</p></div>
      </div>
      <div class="asec"><h3>YOUR INFO</h3>
        <div class="fg"><label>DISCORD USERNAME *</label><input type="text" id="ctxDiscord" placeholder="e.g. username#0000"></div>
      </div>
      <div class="asec"><h3>REASON FOR CONTACT</h3>
        <div class="contact-type-grid" id="contactTypeGrid">
