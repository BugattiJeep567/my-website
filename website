      '<div class="app-item-header"><div><h3>'+esc(a.discord)+'</h3><div class="app-ids">Roblox: '+esc(a.roblox)+' &nbsp;|&nbsp; '+fmtDate(a.date)+' &nbsp;|&nbsp; '+statusBadge+'</div></div>'+
