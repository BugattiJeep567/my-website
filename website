// ══════════════════════════════════════════════
//  COOLDOWN HELPERS (5 min = 300000ms)
// ══════════════════════════════════════════════
var COOLDOWN_MS = 5 * 60 * 1000;

function checkCooldown(key) {
  var last = localStorage.getItem(key);
  if (!last) return 0;
  var diff = Date.now() - parseInt(last);
  return diff < COOLDOWN_MS ? Math.ceil((COOLDOWN_MS - diff) / 1000) : 0;
}
function setCooldown(key) { localStorage.setItem(key, String(Date.now())); }
function fmtCountdown(secs) {
  var m = Math.floor(secs / 60), s = secs % 60;
  return m + ':' + (s < 10 ? '0' : '') + s;
}

