<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Discord Embed Services</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Inter}
html{scroll-behavior:smooth}
body{background:#0f1117;color:#fff;overflow-x:hidden;animation:fadePage .8s}
@keyframes fadePage{from{opacity:0}to{opacity:1}}

nav{position:fixed;top:0;width:100%;background:#0b0d13;padding:18px 10%;display:flex;justify-content:space-between;z-index:1000}
nav a{color:#fff;text-decoration:none;margin-left:25px;font-weight:600;transition:.3s}
nav a:hover{color:#6c8cff}

header{height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:0 20px}
.hero h1{font-size:64px;font-weight:800;opacity:0;animation:fadeUp 1.5s forwards}
.hero p{margin-top:15px;color:#b5b9c9;opacity:0;animation:fadeUp 1.5s .4s forwards}
.btn{display:inline-block;margin-top:25px;padding:14px 28px;background:#6c8cff;border-radius:10px;color:#fff;text-decoration:none;font-weight:600;transition:.3s;opacity:0;animation:fadeUp 1.5s .7s forwards}
.btn:hover{transform:translateY(-3px);box-shadow:0 10px 25px rgba(0,0,0,.3)}

section{padding:120px 10%}
.title{font-size:40px;margin-bottom:40px;text-align:center}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:25px}
.card{background:#151923;padding:20px;border-radius:18px;transition:transform .2s ease, box-shadow .2s ease}
.card img{width:100%;border-radius:12px;margin-bottom:12px}
.card:hover{box-shadow:0 20px 40px rgba(0,0,0,.4)}

.contact{text-align:center}
footer{padding:30px;text-align:center;background:#0b0d13;color:#888}

.reveal{opacity:0;transform:translateY(40px);transition:1s}
.reveal.active{opacity:1;transform:translateY(0)}

@keyframes fadeUp{from{opacity:0; transform:translateY(40px)}to{opacity:1; transform:translateY(0)}}

/* Gradient text */
h1, h2, h3, .title, nav h2, nav a:not(.btn), p{background: linear-gradient(180deg,#ffffff,#9aa0a6);-webkit-background-clip:text;background-clip:text;color:transparent}
</style>
</head>
<body>

<nav>
<h2>Bugatti's Portfolio</h2>
<div>
<a href="#home">Home</a>
<a href="#work">Past Work</a>
<a href="#reviews">Reviews</a>
<a href="#contact">Contact</a>
</div>
</nav>

<header id="home">
<div class="hero">
<h1>Professional Discord Embeds</h1>
<p>Modern • Clean • Built to Impress</p>
<a class="btn" href="#contact">Get Started</a>
</div>
</header>

<section id="work" class="reveal">
<h2 class="title">Past Work</h2>
<div class="cards">
<div class="card tilt"><img src="embed1.png"><h3>Order Information</h3></div>
<div class="card tilt"><img src="embed2.png"><h3>Shop Embed</h3></div>
<div class="card tilt"><img src="embed3.png"><h3>Dashboard Embed</h3></div>
</div>
</section>

<section id="reviews" class="reveal">
<h2 class="title">Client Reviews</h2>
<div class="cards">
<div class="card tilt"><p><b>Baseballfan</b> — "Amazing product! Definitely recommend if you need your work showcased! Great product, fast service." ⭐⭐⭐⭐⭐</p></div>
<div class="card tilt"><p><b>noterollem</b> — "Did an amazing job! Super quick and finished before estimated wait time. Perfection 😍" ⭐⭐⭐⭐⭐</p></div>
<div class="card tilt"><p><b>xanderxd6661</b> — "Great embeds and fast delivery." ⭐⭐⭐⭐⭐</p></div>
</div>
</section>

<section id="contact" class="contact reveal">
<h2 class="title">Contact Me</h2>
<p>Discord: BugattiJeep567</p>
<a class="btn" href="https://discord.com/users/1004885156076728451" target="_blank">Message Me</a>
</section>

<footer>
© 2026 BugattiJeep567. All rights reserved.
</footer>

<script>
const reveals=document.querySelectorAll('.reveal');
window.addEventListener('scroll',()=>{for(const el of reveals){const top=el.getBoundingClientRect().top;if(top<window.innerHeight-100){el.classList.add('active')}}});

const cards=document.querySelectorAll('.tilt');
cards.forEach(card=>{card.addEventListener('mousemove',e=>{const rect=card.getBoundingClientRect();const x=e.clientX-rect.left;const y=e.clientY-rect.top;const midX=rect.width/2;const midY=rect.height/2;const rotateX=((y-midY)/midY)*6;const rotateY=((x-midX)/midX)*-6;card.style.transform=`perspective(600px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.03)`});card.addEventListener('mouseleave',()=>{card.style.transform='perspective(600px) rotateX(0) rotateY(0) scale(1)'})});
</script>

</body>
</html>
