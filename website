//  RENDER HOME
// ══════════════════════════════════════════════
function renderHome() {
  renderCatFilters();
  var hero = document.getElementById('heroSlot');
  var grid = document.getElementById('newsGrid');
  var label = document.getElementById('searchResultsLabel');
  var filtered = articles;
  if (searchQuery) {
    filtered = articles.filter(function(a){
      return a.headline.toLowerCase().indexOf(searchQuery)!==-1 ||
             a.reporter.toLowerCase().indexOf(searchQuery)!==-1 ||
             a.body.toLowerCase().indexOf(searchQuery)!==-1 ||
             a.category.toLowerCase().indexOf(searchQuery)!==-1;
    });
    label.style.display='block';
    label.textContent = filtered.length+' RESULT'+(filtered.length!==1?'S':'')+' FOR "'+searchQuery.toUpperCase()+'"';
    hero.innerHTML='';
    grid.innerHTML = filtered.length ? filtered.map(buildCard).join('') : '<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--muted);font-family:monospace;">No articles found.</div>';
    return;
  } else { label.style.display='none'; }
  if (activeCategory !== 'ALL') filtered = filtered.filter(function(a){return a.category===activeCategory;});
  if (!filtered.length) { hero.innerHTML=''; grid.innerHTML=''; return; }
  var heroArt = null;
  if (pinnedId) heroArt = articles.find(function(a){return a.id===pinnedId;});
  if (!heroArt) heroArt = filtered[0];
  var rest = filtered.filter(function(a){return a.id!==heroArt.id;});
  var imgB = heroArt.image ? '<div class="hero-img-wrap"><img src="'+heroArt.image+'" alt=""></div>' : '<div class="hero-no-img">5</div>';
  var pinB = (pinnedId===heroArt.id) ? '<div class="pin-badge">📌 FEATURED</div>' : '';
  var adminB = '';
  if (loggedIn) {
    var pinLbl = (pinnedId===heroArt.id) ? '📌 UNPIN' : '📌 FEATURE';
    adminB = '<div class="admin-btns"><button class="admin-btn del-btn" onclick="deleteArticle('+heroArt.id+',event)">🗑 DELETE</button><button class="admin-btn pin-btn" onclick="togglePin('+heroArt.id+',event)">'+pinLbl+'</button></div>';
  }
