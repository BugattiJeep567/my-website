    '<div class="hero-info">'+
      '<span class="cat-tag">'+esc(heroArt.category)+'</span>'+
      '<h2>'+esc(heroArt.headline)+'</h2>'+
      '<div class="art-meta">BY <span class="reporter-link" onclick="event.stopPropagation();openReporter(\''+esc(heroArt.reporter)+'\')">'+esc(heroArt.reporter).toUpperCase()+'</span> &nbsp;|&nbsp; '+fmtDate(heroArt.date)+'</div>'+
      '<p class="hero-excerpt">'+expt(heroArt.body,200)+'</p>'+
      '<button class="read-btn" onclick="event.stopPropagation();openArticle('+heroArt.id+')">READ MORE →</button>'+
