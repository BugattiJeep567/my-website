// ══════════════════════════════════════════════
async function deleteArticle(id, e) {
  if (e) e.stopPropagation();
  if (!confirm('Delete this article? Cannot be undone.')) return;
  var a = articles.find(function(x){return x.id===id;});
  var title = a ? a.headline : 'article';
  await sbDelete('articles', id);
  articles = articles.filter(function(x){return x.id!==id;});
  if (pinnedId === id) { pinnedId = null; await sbSetSetting('pinned_id', ''); }
  renderHome(); updateTickerFromArticles();
  addLog('delete', currentUser, 'deleted article', '"'+title+'"', null);
}

async function togglePin(id, e) {
  if (e) e.stopPropagation();
  var a = articles.find(function(x){return x.id===id;});
  var title = a ? a.headline : 'article';
  var wasPinned = pinnedId === id;
  pinnedId = wasPinned ? null : id;
  await sbSetSetting('pinned_id', pinnedId ? String(pinnedId) : '');
  renderHome();
  addLog('pin', currentUser, wasPinned ? 'unpinned article' : 'featured article', '"'+title+'"', null);
}

