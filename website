async function sbFetch(table, opts) {
  opts = opts || {};
  var url = SB_URL + '/rest/v1/' + table;
  if (opts.query) url += '?' + opts.query;
  var res = await fetch(url, {
    method: opts.method || 'GET',
    headers: {
      'apikey': SB_KEY,
      'Authorization': 'Bearer ' + SB_KEY,
      'Content-Type': 'application/json',
      'Prefer': opts.prefer || (opts.method === 'POST' ? 'return=representation' : ''),
    },
    body: opts.body ? JSON.stringify(opts.body) : undefined
  });
  if (!res.ok) { var t = await res.text(); console.error(table, t); return null; }
  var ct = res.headers.get('content-type') || '';
  if (ct.includes('json') && res.status !== 204) return res.json();
  return null;
}

async function sbGet(table, query) { return sbFetch(table, { query: query || 'order=id.desc' }); }
async function sbInsert(table, row) { return sbFetch(table, { method: 'POST', body: row }); }
async function sbUpdate(table, id, row) { return sbFetch(table, { method: 'PATCH', query: 'id=eq.'+id, body: row, prefer: 'return=representation' }); }
async function sbDelete(table, id) { return sbFetch(table, { method: 'DELETE', query: 'id=eq.'+id }); }
async function sbGetSetting(key) {
  var r = await sbFetch('settings', { query: 'key=eq.'+encodeURIComponent(key) });
  return (r && r[0]) ? r[0].value : null;
}
async function sbSetSetting(key, value) {
  await sbFetch('settings', { method: 'POST', body: { key: key, value: value }, prefer: 'resolution=merge-duplicates,return=representation' });
}

