  if (!body)     { showPubMsg('Please write the article body.', false); return; }
  showPubMsg('Publishing...', true);
  var row = { id: Date.now(), headline, reporter, category, caption, body, image: imgData, date: new Date().toISOString(), comments: [], pinned: false };
  var res = await sbInsert('articles', row);
  if (res) {
    articles.unshift(row);
    renderHome(); updateTickerFromArticles(); clearForm();
    addLog('article', currentUser, 'published article', '"'+headline+'"', null);
    showPubMsg('✓ Article published!', true);
    setTimeout(function(){ showTab('home'); }, 1200);
  } else {
    showPubMsg('Error publishing. Try again.', false);
  }
}

function clearForm(){
  ['artHeadline','artReporter','artCaption'].forEach(function(id){document.getElementById(id).value='';});
  document.getElementById('artBody').value='';
  document.getElementById('artCategory').selectedIndex=0;
