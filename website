// ══════════════════════════════════════════════
//  MESSAGES PANEL
// ══════════════════════════════════════════════
var typeColors = { 'General Inquiry':'rgba(100,160,255,0.2);color:#6ab4ff', 'News Tip':'rgba(40,167,69,0.2);color:#6dcf7e', 'Complaint':'rgba(200,16,46,0.2);color:#e87985', 'Partnership':'rgba(212,168,67,0.2);color:#D4A843' };

async function renderMessages() {
  var el = document.getElementById('messagesList');
  el.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-family:monospace;">Loading...</div>';
  var msgs = await sbGet('contacts', 'order=id.desc');
  var unread = msgs ? msgs.filter(function(m){return !m.read;}).length : 0;
  var badge = document.getElementById('unreadBadge');
  if (badge) { if(unread>0){badge.style.display='inline-block';badge.textContent=unread+' NEW';}else{badge.style.display='none';} }
  if (!msgs||!msgs.length) { el.innerHTML='<div class="no-apps">No messages yet.</div>'; return; }
  el.innerHTML = msgs.map(function(m){
    var colorStyle = typeColors[m.type]||'rgba(128,128,128,0.2);color:#aaa';
    var parts=colorStyle.split(';'); var bgStyle=parts[0]; var fgStyle=parts[1]||'color:#aaa';
    var unreadMark = !m.read ? '<span style="display:inline-block;width:8px;height:8px;background:var(--red);border-radius:50%;margin-right:8px;"></span>' : '';
    return '<div class="msg-item'+(!m.read?' unread':'')+'" id="msg-'+m.id+'">'+
      '<div class="msg-header"><div><div class="msg-from">'+unreadMark+esc(m.discord)+'</div></div>'+
      '<div class="msg-meta"><span class="msg-type-badge" style="background:'+bgStyle+';'+fgStyle+';">'+esc(m.type).toUpperCase()+'</span><br>'+fmtDate(m.date)+'</div></div>'+
      '<div class="msg-subject">RE: '+esc(m.subject)+'</div>'+
      '<div class="msg-body">'+esc(m.message)+'</div>'+
      '<div class="msg-actions">'+(!m.read?'<button class="admin-btn pin-btn" onclick="markRead('+m.id+')">✓ Mark Read</button>':'<span style="font-family:monospace;font-size:11px;color:var(--muted);">✓ Read</span>')+
      ' &nbsp;<button class="admin-btn del-btn" onclick="deleteMessage('+m.id+')">🗑 Delete</button></div></div>';
  }).join('');
}

async function markRead(id) {
  var msgs = await sbGet('contacts', 'id=eq.'+id);
  var who = msgs && msgs[0] ? msgs[0].discord : 'user';
  await sbUpdate('contacts', id, { read: true });
  addLog('msg', currentUser, 'read message from', who, null);
  updateUnreadBadge(); renderMessages();
}

async function deleteMessage(id) {
  if (!confirm('Delete this message?')) return;
  var msgs = await sbGet('contacts', 'id=eq.'+id);
  var who = msgs && msgs[0] ? msgs[0].discord : 'user';
  await sbDelete('contacts', id);
  addLog('msg', currentUser, 'deleted message from', who, null);
  updateUnreadBadge(); renderMessages();
}

// ══════════════════════════════════════════════
//  SEARCH
// ══════════════════════════════════════════════
function doSearch(){
  var q=document.getElementById('searchInput').value.trim().toLowerCase();
  searchQuery=q;
  if(!q){clearSearch();return;}
  document.getElementById('searchClearBtn').style.display='block';
  activeCategory='ALL'; renderHome();
}
function clearSearch(){
  searchQuery=''; document.getElementById('searchInput').value='';
  document.getElementById('searchClearBtn').style.display='none';
  document.getElementById('searchResultsLabel').style.display='none';
  renderHome();
}

// ══════════════════════════════════════════════
//  TICKER
// ══════════════════════════════════════════════
function updateTickerFromArticles() {
  var t = document.getElementById('ticker');
  if (!articles.length) { t.innerHTML='DENVER NEWS STATION 5 &nbsp;•&nbsp; YOUR LOCAL SOURCE FOR TRUTH &nbsp;•&nbsp; STAY INFORMED, DENVER'; }
  else { t.innerHTML=articles.map(function(a){return a.headline;}).join(' &nbsp;•&nbsp; '); }
}

async function saveTicker() {
  var v = document.getElementById('tickerInput').value.trim();
  await sbSetSetting('ticker', v);
  if (v) document.getElementById('ticker').innerHTML = v;
  else updateTickerFromArticles();
}

async function clearTicker() {
  await sbSetSetting('ticker', '');
  document.getElementById('tickerInput').value='';
  updateTickerFromArticles();
}

// ══════════════════════════════════════════════
//  ANNOUNCEMENT
// ══════════════════════════════════════════════
async function saveAnnounce() {
  var text = document.getElementById('announceInput').value.trim();
  await sbSetSetting('announce_text', text);
  document.getElementById('announceText').textContent = text;
  addLog('announce', currentUser, 'updated announcement', '"'+text+'"', null);
  await loadSettings();
}

async function toggleAnnounce() {
  var on = await sbGetSetting('announce_on');
  var newVal = on === 'true' ? 'false' : 'true';
  await sbSetSetting('announce_on', newVal);
  addLog('announce', currentUser, newVal==='true' ? 'showed announcement' : 'hid announcement', null, null);
  await loadSettings();
}

async function clearAnnounce() {
  await sbSetSetting('announce_text', '');
  await sbSetSetting('announce_on', 'false');
  document.getElementById('announceInput').value='';
  document.getElementById('announceBar').classList.remove('visible');
  addLog('announce', currentUser, 'cleared announcement', null, null);
}

function dismissAnnounce() {
  sessionStorage.setItem('dns5_announce_dismissed','true');
  document.getElementById('announceBar').classList.remove('visible');
}

// ══════════════════════════════════════════════
//  ACTIVITY LOGS
// ══════════════════════════════════════════════
var LOG_ICONS = { login:{icon:'🔐',cls:'login'}, article:{icon:'📝',cls:'article'}, delete:{icon:'🗑️',cls:'delete'}, app:{icon:'📋',cls:'app'}, msg:{icon:'💬',cls:'msg'}, staff:{icon:'👤',cls:'staff'}, pin:{icon:'📌',cls:'pin'}, announce:{icon:'📢',cls:'announce'} };

async function addLog(type, user, action, detail, meta) {
  await sbInsert('logs', { id:Date.now()+Math.floor(Math.random()*1000), type, username:user||'Unknown', action, detail:detail||null, meta:meta||null, date:new Date().toISOString() });
}

function setLogFilter(filter, btn) {
  activeLogFilter = filter;
  document.querySelectorAll('.log-filter-btn').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  renderLogs();
}

async function renderLogs() {
  var el = document.getElementById('logsList');
  el.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-family:monospace;">Loading...</div>';
  var query = 'order=id.desc&limit=200';
  if (activeLogFilter !== 'ALL') query = 'type=eq.'+activeLogFilter+'&order=id.desc&limit=200';
  var logs = await sbGet('logs', query);
  if (!logs||!logs.length) { el.innerHTML='<div class="no-logs">No activity logged yet.</div>'; return; }
  el.innerHTML = logs.map(function(l){
    var iconInfo = LOG_ICONS[l.type]||{icon:'•',cls:'login'};
    var detailStr = l.detail ? ' <span style="color:var(--gold);">'+esc(l.detail)+'</span>' : '';
    var locationStr = '';
    var subStr = '';
    if (l.meta && l.type==='login') {
      if (l.meta.location) locationStr='<span class="log-location">📍 '+esc(l.meta.location)+'</span>';
      if (l.meta.ip) subStr='IP: '+esc(l.meta.ip);
    }
    return '<div class="log-item">'+
      '<div class="log-icon '+iconInfo.cls+'">'+iconInfo.icon+'</div>'+
      '<div class="log-body"><div class="log-text"><strong>'+esc(l.username)+'</strong> '+esc(l.action)+detailStr+locationStr+'</div>'+(subStr?'<div class="log-sub">'+subStr+'</div>':'')+
      '</div><div class="log-time">'+fmtDate(l.date)+'</div></div>';
  }).join('');
}

async function clearLogs() {
  if (!confirm('Clear all activity logs?')) return;
  await sbFetch('logs', { method:'DELETE', query:'id=gt.0' });
  renderLogs();
}

// ══════════════════════════════════════════════
//  VIEW COUNTER
// ══════════════════════════════════════════════
function getViews(id) {
  try { return parseInt(localStorage.getItem('dns5_views_'+id)||'0'); } catch(e){ return 0; }
}
function incrementViews(id) {
  try {
    var key = 'dns5_viewed_'+id;
    if (sessionStorage.getItem(key)) return; // only count once per session
    sessionStorage.setItem(key, '1');
    var v = getViews(id) + 1;
    localStorage.setItem('dns5_views_'+id, String(v));
  } catch(e){}
}

// ══════════════════════════════════════════════
//  ARCHIVE
// ══════════════════════════════════════════════
function renderArchive() {
  var el = document.getElementById('archiveContent');
  if (!articles.length) { el.innerHTML='<div style="text-align:center;padding:60px;color:var(--muted);font-family:monospace;">No articles yet.</div>'; return; }
  // Group by month
  var groups = {};
  articles.forEach(function(a) {
    var d = new Date(a.date);
    var key = d.getFullYear()+'-'+(d.getMonth()+1);
    var label = d.toLocaleDateString('en-US',{month:'long',year:'numeric'}).toUpperCase();
    if (!groups[key]) groups[key] = { label:label, items:[] };
    groups[key].items.push(a);
  });
  var keys = Object.keys(groups).sort(function(a,b){return b.localeCompare(a);});
  el.innerHTML = keys.map(function(k) {
    var g = groups[k];
    var items = g.items.map(function(a) {
      var img = a.image ? '<img class="archive-item-img" src="'+a.image+'" alt="">' : '<div class="archive-item-no-img">5</div>';
      var views = getViews(a.id);
      return '<div class="archive-item" onclick="openArticle('+a.id+')">'+img+
        '<div class="archive-item-info">'+
          '<span class="cat-tag" style="margin-bottom:6px;">'+esc(a.category)+'</span>'+
          '<h3>'+esc(a.headline)+'</h3>'+
          '<div class="archive-item-meta">BY <span class="reporter-link" onclick="event.stopPropagation();openReporter(\''+esc(a.reporter)+'\')">'+esc(a.reporter).toUpperCase()+'</span></div>'+
        '</div>'+
        '<div class="archive-item-views">👁 '+views+'</div>'+
      '</div>';
    }).join('');
    return '<div class="archive-month">'+
      '<div class="archive-month-title">'+g.label+'<span class="archive-month-count">'+g.items.length+' ARTICLE'+(g.items.length!==1?'S':'')+'</span></div>'+
      '<div class="archive-list">'+items+'</div>'+
    '</div>';
  }).join('');
}

// ══════════════════════════════════════════════
//  PHOTO GALLERY
// ══════════════════════════════════════════════
var galleryImgData = null;
var galleryPhotos = [];

async function loadGallery() {
  var res = await sbGet('settings', 'key=eq.gallery');
  if (res && res[0] && res[0].value) {
    try { galleryPhotos = JSON.parse(res[0].value); } catch(e){ galleryPhotos=[]; }
  }
}

async function renderGallery() {
  if (!galleryPhotos.length) await loadGallery();
  var uploadArea = document.getElementById('galleryUploadArea');
  if (uploadArea) uploadArea.style.display = (loggedIn && !isReporter) ? 'block' : 'none';
  var grid = document.getElementById('galleryGrid');
  if (!galleryPhotos.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--muted);font-family:monospace;">No photos yet.</div>';
    return;
  }
  grid.innerHTML = galleryPhotos.map(function(p, i) {
    var delBtn = (loggedIn && !isReporter) ? '<button class="gallery-delete" onclick="deleteGalleryPhoto('+i+',event)">🗑</button>' : '';
    return '<div class="gallery-item" onclick="openLightbox('+i+')">'+delBtn+
      '<img src="'+p.image+'" alt="'+esc(p.caption||'')+'">'+
      (p.caption ? '<div class="gallery-caption">'+esc(p.caption)+'</div>' : '')+
    '</div>';
  }).join('');
}

function handleGalleryImg(e) {
  var f = e.target.files[0]; if(!f) return;
  var r = new FileReader();
  r.onload = function(ev) {
    galleryImgData = ev.target.result;
    document.getElementById('galleryPreviewImg').src = galleryImgData;
    document.getElementById('galleryUploadPreview').style.display = 'block';
  };
  r.readAsDataURL(f);
}

async function uploadGalleryPhoto() {
  if (!galleryImgData) return;
  var caption = document.getElementById('galleryCaptionInput').value.trim();
  galleryPhotos.unshift({ image: galleryImgData, caption: caption, date: new Date().toISOString() });
  await sbSetSetting('gallery', JSON.stringify(galleryPhotos));
  galleryImgData = null;
  document.getElementById('galleryImgInput').value = '';
  document.getElementById('galleryUploadPreview').style.display = 'none';
  document.getElementById('galleryCaptionInput').value = '';
  addLog('staff', currentUser, 'uploaded photo to gallery', caption||'(no caption)', null);
  renderGallery();
}

function cancelGalleryUpload() {
  galleryImgData = null;
  document.getElementById('galleryImgInput').value = '';
  document.getElementById('galleryUploadPreview').style.display = 'none';
  document.getElementById('galleryCaptionInput').value = '';
}

async function deleteGalleryPhoto(i, e) {
  if (e) e.stopPropagation();
  if (!confirm('Delete this photo?')) return;
  galleryPhotos.splice(i, 1);
  await sbSetSetting('gallery', JSON.stringify(galleryPhotos));
  renderGallery();
}

function openLightbox(i) {
  var p = galleryPhotos[i]; if (!p) return;
  var el = document.createElement('div');
  el.className = 'gallery-lightbox';
  el.innerHTML = '<img src="'+p.image+'" alt="">'+(p.caption?'<div class="gallery-lightbox-caption">'+esc(p.caption)+'</div>':'');
  el.onclick = function(){ document.body.removeChild(el); document.body.style.overflow=''; };
  document.body.appendChild(el);
  document.body.style.overflow = 'hidden';
}

// ══════════════════════════════════════════════
//  REPORTER DASHBOARD
// ══════════════════════════════════════════════
function renderDashboard() {
  var el = document.getElementById('dashboardContent');
  var myArts = articles.filter(function(a){ return a.reporter.toLowerCase()===currentUser.toLowerCase(); });
  var totalViews = myArts.reduce(function(s,a){ return s+getViews(a.id); }, 0);
  var totalComments = myArts.reduce(function(s,a){ return s+(a.comments?a.comments.length:0); }, 0);
  var staffMatch = staffMembers.find(function(s){ return s.name.toLowerCase()===currentUser.toLowerCase(); });
  var avatarSrc = staffMatch && staffMatch.image ? staffMatch.image : null;
  var avatarHtml = avatarSrc
    ? '<img src="'+avatarSrc+'" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--red);">'
    : '<div class="dash-avatar">✍️</div>';

  var artCards = myArts.length
    ? '<div class="news-grid">'+myArts.map(buildCard).join('')+'</div>'
    : '<div style="text-align:center;padding:40px;color:var(--muted);font-family:monospace;">You haven\'t published any articles yet.</div>';

  el.innerHTML =
    '<div class="dash-welcome">'+avatarHtml+
      '<div><h2>Welcome back, '+esc(currentUser)+'</h2>'+
        '<p>You are signed in as a Reporter for Denver News Station 5.</p>'+
        '<div style="display:flex;gap:10px;margin-top:14px;">'+
          '<button class="btn-red" onclick="showTab(\'write\')" style="font-size:12px;padding:10px 20px;">✏️ WRITE ARTICLE</button>'+
        '</div>'+
      '</div>'+
    '</div>'+
    '<div class="dash-stats">'+
      '<div class="dash-stat"><span class="dash-stat-num">'+myArts.length+'</span><span class="dash-stat-label">ARTICLES PUBLISHED</span></div>'+
      '<div class="dash-stat"><span class="dash-stat-num">'+totalViews+'</span><span class="dash-stat-label">TOTAL VIEWS</span></div>'+
      '<div class="dash-stat"><span class="dash-stat-num">'+totalComments+'</span><span class="dash-stat-label">TOTAL COMMENTS</span></div>'+
    '</div>'+
    '<div class="dash-articles-title">YOUR ARTICLES</div>'+
    artCards;
}

// ══════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════
function esc(s){ if(!s)return''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function expt(txt,max){ if(!txt)return''; return txt.length>max?txt.slice(0,max).trim()+'...':txt; }
function fmtDate(iso){ var d=new Date(iso); return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})+' '+d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}); }
</script>
